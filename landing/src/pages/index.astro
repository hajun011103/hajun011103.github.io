---
// Landing page for hajun011103.github.io
// The three sections link to the Quartz-published areas. Those links resolve
// once the deploy step (Step 4) mounts Quartz under /study, /research, /projects.
const sections = [
  {
    title: "Study",
    href: "/study/",
    tag: "notes",
    desc: "Notes on machine learning, computer vision, and the math underneath.",
  },
  {
    title: "Research",
    href: "/research/",
    tag: "papers",
    desc: "Papers, experiments, and work in progress.",
  },
  {
    title: "Projects",
    href: "/projects/",
    tag: "builds",
    desc: "Things I've built — including 3D Gaussian Splatting.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hajun Jang</title>
    <meta
      name="description"
      content="Hajun Jang — study notes, research, and projects in machine learning and computer vision."
    />
  </head>
  <body>
    <!--
      HERO — reserved for a future 3D Gaussian Splatting viewer.
      The #hero-canvas element below is the mount point for the splat viewer.
      For now it shows a soft animated gradient so the section isn't empty.
    -->
    <header class="hero">
      <div id="hero-canvas" class="hero__bg" aria-hidden="true"></div>
      <div class="hero__content">
        <h1 class="hero__name">Hajun Jang</h1>
        <p class="hero__tagline">
          Machine learning &middot; Computer vision &middot; 3D reconstruction
        </p>
      </div>
      <div class="hero__hint" aria-hidden="true">
        <span>explore</span>
        <span class="hero__chevron">&darr;</span>
      </div>
    </header>

    <main class="sections" aria-label="Sections">
      {
        sections.map((s) => (
          <a class="card" href={s.href}>
            <span class="card__tag">{s.tag}</span>
            <h2 class="card__title">{s.title}</h2>
            <p class="card__desc">{s.desc}</p>
            <span class="card__arrow" aria-hidden="true">
              &rarr;
            </span>
          </a>
        ))
      }
    </main>

    <footer class="footer">
      <a href="https://github.com/hajun011103" rel="me noopener" target="_blank">
        github.com/hajun011103
      </a>
    </footer>

    <style is:global>
      :root {
        --bg: #08080c;
        --bg-elev: #10101a;
        --text: #e9e9f2;
        --muted: #9797ad;
        --border: #21212f;
        --border-hover: #38385a;
        --accent: #7c6cff;
        --accent-2: #3fd0c9;
        --radius: 16px;
        --maxw: 1000px;
      }

      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI",
          Roboto, "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: inherit;
        text-decoration: none;
      }

      /* ---------- HERO ---------- */
      .hero {
        position: relative;
        min-height: 100svh;
        display: grid;
        place-items: center;
        text-align: center;
        overflow: hidden;
        padding: 2rem;
      }
      .hero__bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        background:
          radial-gradient(
            55% 55% at 28% 30%,
            rgba(124, 108, 255, 0.28),
            transparent 62%
          ),
          radial-gradient(
            50% 50% at 78% 68%,
            rgba(63, 208, 201, 0.2),
            transparent 60%
          ),
          var(--bg);
        animation: drift 20s ease-in-out infinite alternate;
      }
      .hero__bg::after {
        /* subtle vignette to focus the center */
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          70% 70% at 50% 45%,
          transparent 55%,
          rgba(0, 0, 0, 0.55)
        );
      }
      @keyframes drift {
        from {
          transform: scale(1) translate(0, 0);
        }
        to {
          transform: scale(1.12) translate(2%, -2%);
        }
      }
      .hero__content {
        position: relative;
        z-index: 1;
      }
      .hero__name {
        margin: 0;
        font-size: clamp(2.6rem, 8vw, 5.5rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        background: linear-gradient(180deg, #ffffff, #b9b9d6);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .hero__tagline {
        margin: 0.75rem 0 0;
        color: var(--muted);
        font-size: clamp(0.95rem, 2.4vw, 1.15rem);
        letter-spacing: 0.01em;
      }
      .hero__hint {
        position: absolute;
        bottom: 1.75rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
        color: var(--muted);
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }
      .hero__chevron {
        font-size: 1rem;
        animation: bob 1.8s ease-in-out infinite;
      }
      @keyframes bob {
        0%,
        100% {
          transform: translateY(0);
          opacity: 0.6;
        }
        50% {
          transform: translateY(4px);
          opacity: 1;
        }
      }

      /* ---------- SECTIONS ---------- */
      .sections {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(3rem, 8vw, 6rem) 1.25rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.25rem;
      }
      .card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1.6rem 1.5rem 3rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition: transform 0.18s ease, border-color 0.18s ease,
          box-shadow 0.18s ease;
      }
      .card:hover {
        transform: translateY(-4px);
        border-color: var(--border-hover);
        box-shadow: 0 12px 40px -18px rgba(124, 108, 255, 0.55);
      }
      .card__tag {
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-2);
      }
      .card__title {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 650;
        letter-spacing: -0.01em;
      }
      .card__desc {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
      }
      .card__arrow {
        position: absolute;
        right: 1.4rem;
        bottom: 1.2rem;
        font-size: 1.25rem;
        color: var(--muted);
        transition: transform 0.18s ease, color 0.18s ease;
      }
      .card:hover .card__arrow {
        color: var(--accent);
        transform: translateX(4px);
      }

      /* ---------- FOOTER ---------- */
      .footer {
        text-align: center;
        padding: 2.5rem 1rem 3.5rem;
        color: var(--muted);
        font-size: 0.85rem;
      }
      .footer a {
        border-bottom: 1px solid transparent;
        transition: border-color 0.18s ease, color 0.18s ease;
      }
      .footer a:hover {
        color: var(--text);
        border-color: var(--border-hover);
      }

      @media (prefers-reduced-motion: reduce) {
        .hero__bg,
        .hero__chevron {
          animation: none;
        }
      }
    </style>
  </body>
</html>

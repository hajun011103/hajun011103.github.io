---
// /research/ — Astro overview page.
// Curate cards here that link into your Quartz notes at /research/<slug>.
// To add one, uncomment the array items below (href must match a note you publish
// into the vault's future research folder).
const items: { title: string; href: string; desc: string }[] = [
  // { title: "Paper review: XYZ", href: "/research/xyz", desc: "One-line summary." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Research &middot; Hajun Jang</title>
    <meta name="description" content="Research, papers, and experiments by Hajun Jang." />
  </head>
  <body>
    <main class="wrap">
      <a class="back" href="/">&larr; Home</a>
      <header class="head">
        <span class="tag">research</span>
        <h1>Research</h1>
        <p class="lede">Papers, experiments, and work in progress.</p>
      </header>

      {
        items.length === 0 ? (
          <p class="empty">아직 준비 중입니다 — 곧 채워집니다.</p>
        ) : (
          <div class="grid">
            {items.map((it) => (
              <a class="card" href={it.href}>
                <h2>{it.title}</h2>
                <p>{it.desc}</p>
              </a>
            ))}
          </div>
        )
      }
    </main>

    <style is:global>
      :root {
        --bg: #08080c;
        --bg-elev: #10101a;
        --text: #e9e9f2;
        --muted: #9797ad;
        --border: #21212f;
        --border-hover: #38385a;
        --accent: #7c6cff;
        --accent-2: #3fd0c9;
        --radius: 16px;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
          "Apple SD Gothic Neo", "Noto Sans KR", sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1000px; margin: 0 auto; padding: 3rem 1.25rem 5rem; }
      .back {
        color: var(--muted);
        font-size: 0.9rem;
        border-bottom: 1px solid transparent;
        transition: color 0.18s ease, border-color 0.18s ease;
      }
      .back:hover { color: var(--text); border-color: var(--border-hover); }
      .head { margin: 2.5rem 0 2rem; }
      .tag {
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-2);
      }
      .head h1 {
        margin: 0.3rem 0 0.5rem;
        font-size: clamp(2rem, 6vw, 3rem);
        letter-spacing: -0.02em;
      }
      .lede { margin: 0; color: var(--muted); font-size: 1.05rem; }
      .empty {
        margin-top: 3rem;
        padding: 3rem;
        text-align: center;
        color: var(--muted);
        border: 1px dashed var(--border);
        border-radius: var(--radius);
      }
      .grid {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.25rem;
      }
      .card {
        padding: 1.5rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        transition: transform 0.18s ease, border-color 0.18s ease;
      }
      .card:hover { transform: translateY(-4px); border-color: var(--border-hover); }
      .card h2 { margin: 0 0 0.4rem; font-size: 1.3rem; }
      .card p { margin: 0; color: var(--muted); font-size: 0.95rem; }
    </style>
  </body>
</html>
